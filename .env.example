# ──────────────────────────────────────────────────────────────────────────────
# CollegeMap — Environment Variables
# Copy this file to .env.local for local development.
# Add all these variables in Vercel: Project → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (optional) ───────────────────────────────────────────────────────
# Used for page-visit tracking, report logging, and lead storage.
# If not set, audit/lead routes skip silently (no errors).
# Get these from: https://supabase.com → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── SMTP Email (required for "Email My Report" feature) ───────────────────────
# Without these, /api/leads returns 503 and the email form won't work.
#
# Gmail example (use an App Password, not your Gmail password):
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Generate a password for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
# Optional: custom From address (defaults to SMTP_USER)
SMTP_FROM=CollegeMap <your-email@gmail.com>

# ── Optional / advanced ───────────────────────────────────────────────────────
# Set to "true" only if using a self-signed cert on a private Supabase instance.
# Leave unset (or set to "false") for Supabase Cloud.
# SUPABASE_SSL_REJECT_UNAUTHORIZED=false
